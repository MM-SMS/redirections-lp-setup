"height\":960,\"pixelFormat\":\"yuv420p\",\"rFrameRate\":\"25/1\",\"width\":540}}","built_by":"gen3-split-n-stitch","time_to_ready":152.110178837},"url":"https://embed-ssl.wistia.com/deliveries/318e2badebeb482f164498bfe194e81d35200a6c.bin","created_at":1771430669,"segment_duration":3,"opt_vbitrate":1800},{"is_enhanced":false,"type":"hd_mp4_video","slug":"mp4_h264_951k","display_name":"720p","details":{},"container":"mp4","codec":"h264","width":720,"height":1280,"ext":"mp4","size":287945613,"bitrate":951,"public":true,"status":2,"progress":1.0,"metadata":{"max_bitrate":3085432,"average_bitrate":974814,"early_max_bitrate":2058536,"av_stream_metadata":"{\"Audio\":{\"channels\":2,\"channelLayout\":\"stereo\",\"Codec ID\":\"mp4a-40-2\",\"codec\":\"aac\",\"codecType\":\"audio\",\"duration\":2363.076009,\"sampleFormat\":\"fltp\",\"sampleRate\":44100},\"Video\":{\"avgFrameRate\":\"25/1\",\"bitRate\":\"842270\",\"Codec ID\":\"avc1\",\"codec\":\"h264\",\"colorPrimaries\":\"bt709\",\"colorSpace\":\"bt709\",\"colorTransfer\":\"bt709\",\"duration\":2363.08,\"height\":1280,\"pixelFormat\":\"yuv420p\",\"rFrameRate\":\"25/1\",\"width\":720}}","built_by":"gen3-split-n-stitch","time_to_ready":293.541026482},"url":"https://embed-ssl.wistia.com/deliveries/f05c02c729cffec784026351d4837feaf18323e8.bin","created_at":1771430669,"segment_duration":3,"opt_vbitrate":3750},{"is_enhanced":false,"type":"hd_mp4_video","slug":"mp4_h264_1718k","display_name":"1080p","details":{},"container":"mp4","codec":"h264","width":1080,"height":1920,"ext":"mp4","size":519766553,"bitrate":1718,"public":true,"status":2,"progress":1.0,"metadata":{"max_bitrate":5432240,"average_bitrate":1759624,"early_max_bitrate":3968312,"av_stream_metadata":"{\"FastStart\":true,\"Audio\":{\"channels\":2,\"channelLayout\":\"stereo\",\"Codec ID\":\"mp4a-40-2\",\"codec\":\"aac\",\"codecType\":\"audio\",\"duration\":2363.076009,\"sampleFormat\":\"fltp\",\"sampleRate\":44100},\"Video\":{\"avgFrameRate\":\"25/1\",\"bitRate\":\"1627108\",\"Codec ID\":\"avc1\",\"codec\":\"h264\",\"colorPrimaries\":\"bt709\",\"colorSpace\":\"bt709\",\"colorTransfer\":\"bt709\",\"duration\":2363.08,\"height\":1920,\"pixelFormat\":\"yuv420p\",\"rFrameRate\":\"25/1\",\"width\":1080}}","built_by":"render-pipeline","time_to_ready":117.510607386},"url":"https://embed-ssl.wistia.com/deliveries/5f5c30edc4522083ae77e353554a9bfbd027e3f2.bin","created_at":1771430669,"segment_duration":3,"opt_vbitrate":5625},{"is_enhanced":false,"type":"storyboard","slug":"storyboard_3550x4000","display_name":"Storyboard","details":{},"width":3550,"height":4000,"ext":"jpg","size":1784484,"bitrate":0,"public":true,"status":2,"progress":1.0,"metadata":{"frame_count":200,"aspect_ratio":0.5625,"frame_height":200,"frame_width":355,"built_by":"render-pipeline","time_to_ready":82.884290611},"url":"https://embed-ssl.wistia.com/deliveries/30ffec7850c5864aaf42aaa78eb2c95e1558c7cd.bin","created_at":1771430669},{"is_enhanced":false,"type":"still_image","slug":"still_image_1080x1920","display_name":"Thumbnail Image","details":{},"width":1080,"height":1920,"size":1644308,"bitrate":0,"public":true,"status":2,"progress":1.0,"metadata":{"av_stream_metadata":"{\"FastStart\":false,\"Audio\":{},\"Video\":{\"codec\":\"png\",\"colorPrimaries\":\"bt709\",\"colorSpace\":\"gbr\",\"colorTransfer\":\"iec61966-2-1\",\"height\":1920,\"pixelFormat\":\"rgba\",\"rFrameRate\":\"25/1\",\"width\":1080}}"},"url":"https://embed-ssl.wistia.com/deliveries/f983f4ea97ea73d1dd87cfb765ca494a.bin","created_at":1771499324}],"branding":false,"createdAt":1771430669,"distilleryUrl":"https://distillery.wistia.com/x","duration":2363.08,"enableCustomerLogo":true,"firstEmbedForAccount":false,"firstShareForAccount":false,"availableTranscripts":[{"bcp47LanguageTag":"en","familyName":"English","familyNativeName":"English","hasCaptions":true,"hasVideoStream":false,"name":"English","nativeName":"English","wistiaLanguageCode":"eng","language":"eng","ietf_language_tag":"eng","alpha3_terminologic":"eng","alpha3_bibliographic":"eng","iso639_2_language_code":"en","english_name":"English","native_name":"English","right_to_left":false,"alpha3Bibliographic":"eng","alpha3Terminologic":"eng","ietfLanguageTag":"eng","iso6392LanguageCode":"en","genericName":"English","genericNativeName":"English"}],"hashedId":"dydzg9zns6","mediaId":144455403,"mediaKey":"wistia-production_144455403","mediaType":"Video","name":"UGC2 GS V3.2 MOBILE","preloadPreference":null,"progress":1.0,"protected":false,"projectId":10380788,"seoDescription":"a Genius Song video","showAbout":true,"status":2,"type":"Video","playableWithoutInstantHls":true,"stats":{"loadCount":243327,"playCount":126483,"uniqueLoadCount":193207,"uniquePlayCount":109663,"averageEngagement":0.215753},"trackingTransmitInterval":78,"liveStreamEventDetails":null,"integrations":{},"captions":[{"language":"eng","text":"Manifestation is for suckers. If manifestation work, why is everyone still poor?\n\nThis is why the law of attraction doesn't work. The strongest energy in the universe is not positive thinking meditation or the law of attraction. It's brain waves, specifically a single brain wave. MIT found that all lucky, wealthy, successful people have this one brain wave in their mind at all times.\n\nThis brain wave is suppressed at an early age by our modern way of life, keeping this god given ability switched off in most people. This is the big new thing for twenty twenty six. Harvard and Stanford have been studying this exact thing. MIT, Harvard, there are even studies from the CIA.\n\nIt's a seven second brain trick.\n\nAnd you do it on the couch?\n\nOn the couch. Yeah. On the couch. It took like seven seconds. Maybe seven seconds. My brain feels smart again.\n\nMoney just appears in my life now.\n\nI can read so much faster now. I remember everything. You can do the same thing with meditation, but it'll take you ten years instead of a couple minutes. It's like my IQ is higher.\n\nMy grandson is getting straight A's now. I'm remembering the Spanish I learned in high school. It's My life has really turned around. It feels magical, like I'm at the center of some wonderful little fairy tale now.\n\nThe root of our problems comes down to one brainwave. You have this brainwave. It's dormant. All it takes is a seven second morning ritual to activate the brainwave.\n\nThink you know what it is? I'd be surprised if you did. This brainwave is a brand new discovery in twenty twenty six. It's linked to genius abilities.\n\nGreat ideas just come to you. You learn faster. Lucky things happen. Princeton studied this brainwave, but we've all been ignoring it.\n\nSo we're gonna activate this brainwave now because it's not on YouTube, TikTok, or any books on Amazon. My name is doctor Robert Lake. The breakthrough exploded when a colleague handed me a stunning report from Princeton, and stay with me, this gets good. When you were a kid, you remembered everything.\n\nYou learned to read, write, speak, and it was easy. It was like the universe had your back. Here's the million dollar question, what happened? For thirty years, researchers have failed to answer this question.\n\nBut imagine if we could reactivate that brain power in you today. This paper published on December twenty seventh twenty twenty five may hold the key to you doing that. Listen to this. The world renowned neurologist, doctor Alan Snyder, says we all have access to genius abilities as kids, such as the perfect pitch, photographic memory, or extreme mathematical intuition.\n\nBut these genius abilities are suppressed by the school system and our modern way of life. Is he right? Princeton and Berkeley seemed to think so. They found nearly all kids had access to a form of creative genius that taps into your intuition where you have eureka moments and great insights seem to come to you.\n\nBut the rabbit hole goes even deeper. British scientists wanted to test just how far the creative genius of kids could go and what they found shocked them. It turns out kids not only had genius abilities, but many could somehow know things in advance. It's a bit spooky, but in their double blind study, they found several kids were able to know who was calling before picking up the phone.\n\nMeanwhile, adults showed none of this ability. Now I'm not saying we were psychics as kids because we weren't, but the evidence is clear. You had genius abilities as a kid. You had God given creativity, intuition, and remarkable brain power.\n\nSo what robbed us of this genius power that was once yours? Scientists call it the decline effect. You're born with genius abilities, but by adulthood, you no longer have access. Have you ever heard someone say cognitive decline starts at seventy?\n\nThey're wrong. Cognitive decline doesn't start at seventy. It starts at seven. But as I poured over the research, it dawned on me.\n\nIf I could discover what's really going on at the cellular level, then maybe we could reactivate that brainpower in you. And I have good news. It turns out that we can. The answer comes down to the fastest growing field in neuroscience, brain waves.\n\nIt turns out if you look at a child's consciousness with an EEG machine, you can see their brain waves. And what you see is kids have a very active gamma wave. But when you look at an adult's consciousness, you see almost no gamma wave. It's like it's been deactivated, and neuroscientists know that people with more gamma tend to be geniuses.\n\nGreat ideas flow to them. Synchronicities happen. Miracles occur. And I know it's not a scientific term, but it's almost as if you become lucky and things just start working out more and more for you in your life.\n\nThe problem is as we age, our gamma seems to disappear. That's when life no longer seems magical. We feel slow. We forget names.\n\nIt's hard to learn new things. Let me explain. This gamma discovery is the root of all our problems. Recently, colleagues at the Einstein Center in Berlin found the famous flow state was linked to the gamma brainwave.\n\nAll athletes and musicians seek to be in the flow state, and so should you. Because the flow state is when you're in the zone and everything becomes easier for you. When Tom Brady throws a game winning touchdown, he's in a flow state with gamma. When Taylor Swift is performing for seventy thousand people, she's in a flow state with Gamma.\n\nResearchers in Wisconsin even studied a monk known as the happiest man alive and found his brain was pure Gamma wave. Remarkable events, transformations take place at gamma. Problems get solved. Genius happens.\n\nYou might call it magic or good luck, but it's something different. It's almost like people who tap into gamma can shape reality, and the universe has your back. It's because when you're at the gamma level, several regions of your brain activate at the same time and connect to each other. It's like having a super brain, but you'd be amazed to discover it's not new.\n\nYou can go back a century and still see leaders seeking gamma. Edison even invented a complicated device that activated gamma for him. He wrote that this device solved his hardest problems for him. Have you ever wondered why so many billionaires say they wake up at exactly four AM and not at a different hour?\n\nWell, these billionaires know how their brain works. They're taking advantage of the gamma brainwave, which is elevated when you wake up at that time. It makes deep and profound learning very easy where you don't have to work nearly as hard. The gamma wave is so transformative that in the lab, my colleagues and I refer to it as the super brainwave.\n\nThere's even research from Columbia University showing your gamma could influence another person. This could mean that if you have more gamma, you could bless your kids with it and pass it down to them. I want you to understand. This is the root cause of our problems and bad luck.\n\nWe are born with miraculous human ability. But from the time we are born, the modern way of life systematically suppresses this super brainwave, rendering it mostly deactivated. Our powers and destiny have been stolen from us at the neural level. Although my critics laugh when I say it, this is truly the great swindle of our lifetime.\n\nThis is why it takes you so long to learn a new skill that could improve your finances while a few lucky people can pick it up with ease. It's why you think of what you should have said after the conversation. It's why love and relationships go sour. It's why great insights and eureka moments come to others, but rarely to you.\n\nThe deck was stacked against us, causing the God given brainwave that could transform your life and luck to and shrink and shrink before you even had a chance as an adult. And the longer this goes on, the more frustrated you'll feel. This is why so many people become bitter and resentful as they get older. They're missing out on God's gift to them, but they can turn it all around starting as soon as today, and so can you.\n\nHere are the four ways we know for a fact we'll activate your gamma wave. Number one, meditation. If you can meditate twice a day for twenty minutes a day, you'll begin to activate your gamma wave. This This one is not a great option for a lot of folks because it's very hard and time consuming.\n\nNumber two, wake up at four AM. This is what many billionaires do, but it's also very hard and tiring. I don't even do this myself. Number three, use a biofeedback machine.\n\nBiofeedback machinery has been shown to help activate your super brainwave, but in person sessions start at around three hundred dollars per hour, and an in home biofeedback machine will set you back about seven thousand dollars. Number four, you can use a special sound wave. This is the easiest way by far, and I have the ideal sound wave for you, but let me tell you why. When my colleagues and I began researching how to activate this super brainwave, we wanted something that was simple, easy, and that you could do at home.\n\nAnd we knew the solution would be unique because this hasn't existed until now. And there were thousands of studies, not to mention ancient texts that have been around for centuries to go through. So let me give you a clue. Nikola Tesla advised, if you want to find the secrets of the universe, think in terms of frequency and vibration.\n\nHe was a bit out there, but he was right. We realized sound waves were a perfect solution because sound is all about vibrations. And our sound wave used brain entrainment, which works by guiding the brain into gamma. But there's a problem.\n\nBrain entrainment normally takes one hour per session. But after many late nights and coffee runs at the lab, my PhDs were able to turn one hour of brain entrainment into a seven minute sound wave. You'll love what happened next. Being researchers, we tested it on ourselves first.\n\nWe wondered, would it work like the research showed, or did we forget something? We listened to the sound wave every day for seven minutes, making sure not to miss a day. After a few short weeks, we knew it was working. When one colleague reported he'd finished his book, which had been sitting incomplete on his computer for three years.\n\nHe said the book just suddenly came together for him, but there's more. Another colleague reported his persistent migraine headaches had just disappeared. After a week of listening, his son's test results had gone from a c to an a at school. It was transforming his entire family, and it didn't stop there.\n\nAfter three weeks of listening, a female colleague who had been divorced and single for several years accidentally bumped carts with a man at Trader Joe's. That man is now her fiance. It all felt a bit magical. Another colleague reported losing sixteen pounds from his belly.\n\nAnd after eleven years of cigarettes, another reported he'd lost the urge to smoke and quit. His behavior towards smoking had been reprogrammed, and it wasn't just him. His wife had been listening to the sound wave every day too, and she'd gotten the promotion at work she swore she'd be passed over for, which included a signing bonus. We call this seven minute sound wave the genius song and turned it into a digital audio track anyone could listen to right now.\n\nSo far, it's helped eighteen thousand three hundred sixty six everyday Americans start to live a lucky and blessed life. The Genius song is the first sound wave developed by neuroscientists that uses advanced brain entrainment to activate gamma and the mind power that can transform your life. It's simple, easy, and you can do it at home. Just pop on a pair of headphones and relax for seven minutes listening to the calming sound wave.\n\nBeneath your awareness, the advanced brain entrainment will begin activating your gamma by connecting several regions of your brain to each other. It starts working the very first time you listen to it. You'll do it from the privacy of your own home, and you don't need to meditate, repeat a mantra, or write anything down. You just listen to the sound wave for seven minutes every day as it synchronizes with your brain waves and activates your gamma.\n\nThe result is an activated super brain wave, reconnecting you with the brain power that's currently dormant in you. You'll notice insights and eureka moments begin to flow to you. Difficult problems will become solved with little to no effort on your part. As you listen more each day, things shift and new abilities begin to unlock.\n\nYou'll automatically start thinking bigger about your life, and you'll notice a sense of easy confidence in your quest for amazing health, amazing relationships, amazing career. And did you know deep learning happens in Gamma? So you'll find it easier to remember key ideas or learn a new skill, like a musical instrument or even a new money making skill. Best of all, operating at the Gamma level is the key to things falling into place for you and your family.\n\nSynchronicities happen. Abundance happens. Opportunities come your way. Give it a few weeks, and you might find your behavior towards food or exercise or even giving up smoking has changed, and you feel in control.\n\nSince its release, the Genius song has helped thousands of people around the world experience a transformation in their life. People like Rachel, a nurse from Tustin, California who wrote me and said, before I started using this product, I felt I was at the mercy of events. Bad things would happen and I had no control. Over time, I'd accepted this as my fate.\n\nEven when something good would happen like when my daughter got engaged, it was a sinking feeling because I felt like the universe would balance out the good and send me something bad. Over the years, I tried meditation, yoga, and even the law of attraction stuff, but nothing seemed to truly impact my life. Within two weeks of listening to the genius song, this product has made me a new woman. I'm much kinder to my kids and husband, and I'm learning to speak French.\n\nIt's actually easy now. It's hard to describe. My life feels enchanted now, like I'm the center of some wonderful little fairy tale. While I would never be able to afford to fly to doctor Lake and see him in person, I can't thank him and his colleagues enough for making this available to people who need it.\n\nFive stars. Here's another one. I wanted to try this for the financial aspect. I'd hope tapping into Gamma would unlock that genius creative ability we all had as young kids and helped me grow my Amazon business.\n\nI also hope my six year old and eight year old would take an interest in bettering their mind too when they saw me do it. I didn't notice much the first week, but in week two, my wife commented that I'd seem sharper. She joked you were always smart, but it seems like your IQ has gone up twenty points. It's been a couple months now, and my Amazon business is doing well enough that I quit my nine to five.\n\nWhen problems arise, I don't get worried now. I just know Gamma will figure it out for me. And within a couple days, the solution just comes to me. I told my friends it's my new superpower.\n\nMy kids love listening to this product before bed. The best benefit of all might be that they don't fight us on bedtime anymore. I hope this helps someone who wants to improve their finances like I did. I love this product.\n\nThat's from Michael in Dallas. Hannah from Manhattan said, since I was a kid, my family has been superstitious. Everyone says we have bad luck. A few years ago, my mom was sick and the doctor told my mom she needed to have her leg amputated to save her life.\n\nSo she had the surgery, and then we found out after she didn't need to have her leg amputated, things like that. So I was excited when doctor Lake talked about what happens when we're at the gamma level more often, and this sound wave has changed everything for me. My relationship with my husband has transformed, and in a team meeting, an idea struck me out of nowhere that's grown our entire company. A little after that, I got promoted.\n\nMy family's so called curse is no more. I can't believe how different I feel now. I feel like everyone should know about this product. I have recommended it to all my friends and family.\n\nI've received hundreds of emails like this, and it inspires me to spread the word of the Genius song to as many people as possible. The Genius song is much faster than a meditation practice and much more affordable than a seven thousand dollar biofeedback machine. And because several regions of your brain activate at the same time, transformations in people's finances, health, relationships, and career are not uncommon. It's time for you to experience life with the brainpower nature had in mind for you before our modern way of life deactivated it.\n\nJust imagine waking up each morning refreshed with solutions to problems handed to you and real clarity about how to get the outcome you want. Imagine grasping a new idea the first time you hear it, even though it takes others days or weeks to get it. Imagine reconnecting with your mind's intuitive power where great insights and creativity flow to you as you need them. Imagine the look on a friend's face as you handle a difficult conversation with ease because the right word now comes to you.\n\nYou suddenly have access to the insights that make your career take off, or you learn a new money making skill quickly and improve your finances. Maybe you stun your family by learning a new language or musical instrument, and it's actually fun. Great opportunities are abundant. Things start to go your way, and life gets better and better for you and your family.\n\nThat's the life you deserve, and you can have it all today when you claim your copy of the genius song. By now, you should realize that I take great pride in the work that I do as one of America's most diligent neuroscientists. My reputation is everything, and I would only ever attach my name to a product if I one hundred percent believe in it. Bottom line is a lot of time and money goes into this research.\n\nHowever, when you compare the time the genius song takes to the months of time that even basic meditation requires, Or when you compare the price to the expensive equipment out there that promises to do the same thing, it will seem like a bargain. And given the transformation that activating your gamma wave can have on your life, we could easily offer this at a very high price. Think about it. How much would you be willing to invest to have difficult problems solved for you with a great insight?\n\nHow much would you pay to land a promotion or get a raise? What about having your behavior towards food or exercise or smoking reprogrammed for you? Or watching your relationship with your partner or your kids transform? What would it be worth to not just feel like the universe has your back, but to actually see it guide and support you each day?\n\nThink about the power and control you're going to feel. What would you be willing to spend for this kind of transformation? Two hundred dollars, three hundred dollars, five hundred dollars? How much has it cost you in your lifetime struggling to get what you want?\n\nBecause remember what Columbia University has found. The gamma region of your brain can influence another. That means by activating it, you could support your kids or your partner with it too. But if you don't, that means they miss out on the benefits too.\n\nYou really can't put a price on being tapped into your mind's intuitive ability and having the things that you want happen for you. Many of my colleagues have suggested that this product would be an incredible value even at five hundred dollars. However, because my main goal with this product was to help all of the people who couldn't afford to come see me at my New York City clinic, we cut out all middlemen and made it available only through this website. That means you don't need to invest five hundred dollars to get your hands on this breakthrough sound wave.\n\nIn fact, you don't need to invest two hundred dollars or even one hundred dollars. That's because we are offering the Genius song today for just forty nine dollars. That's more than forty percent off our original price. But that's not all.\n\nBecause you've made it this far into the presentation, it's obvious you're serious about experiencing a breakthrough in your life, and you are interested in seeing how this one of a kind solution can help you the same way it's helping thousands of others, which is why I want to let you try this cutting edge sound wave at a special price available only through this video on this page today. And for a limited time only, I'd like to offer you the Genius song for just thirty nine dollars. That's another ten dollars off. And all I ask in return is that you consider sending us a success story once you experience the transformation that many of ou